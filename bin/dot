#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CONFIG_FILE="$DOTFILES_DIR/dot.toml"
PROGRESS_FILE="$DOTFILES_DIR/.dot-install-progress"

RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_step() { echo -e "${CYAN}${BOLD}==>${NC} $1"; }

info() { gum log --time TimeOnly --level info "$1"; }
warn() { gum log --time TimeOnly --level warn "$1"; }

spin() {
	local title="$1"
	shift
	gum spin --spinner dot --title "$title" -- "$@"
}

confirm() {
	gum confirm "$1"
}

stow_log() {
	stow "$@" 2>&1 | while IFS= read -r line; do info "$line"; done
}

install_tool() {
	local name="$1" check="$2" install_cmd="$3"

	if eval "$check"; then
		info "$name already installed."
	else
		spin "Installing $name..." bash -c "$install_cmd"
		info "$name installed."
	fi
}

show_header() {
	gum style --border double --margin "0 1" --padding "0 2" --foreground 212 --bold "dot — dotfiles manager"
}

ensure_gum() {
	if command -v gum &>/dev/null; then return 0; fi

	log_error "gum is not installed. Installing..."
	if command -v brew &>/dev/null; then
		brew install gum
	elif command -v apt &>/dev/null; then
		sudo mkdir -p /etc/apt/keyrings
		curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg
		echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" | sudo tee /etc/apt/sources.list.d/charm.list
		sudo apt update && sudo apt install -y gum
	else
		log_error "Install gum manually: https://github.com/charmbracelet/gum#installation"
		exit 1
	fi
	info "gum installed."
}

ensure_tomlq() {
	if command -v tomlq &>/dev/null; then return 0; fi

	log_error "tomlq (kislyuk/yq) is not found. Installing..."
	if command -v brew &>/dev/null; then
		brew install python-yq
	elif command -v apt &>/dev/null; then
		sudo apt update && sudo apt install -y yq
	else
		log_error "Install yq manually: pip install yq"
		exit 1
	fi

	if ! command -v tomlq &>/dev/null; then
		log_error "tomlq installation failed."
		exit 1
	fi
	info "tomlq installed."
}

step_done() { grep -qxF "$1" "$PROGRESS_FILE" 2>/dev/null; }
mark_done() { echo "$1" >>"$PROGRESS_FILE"; }
reset_progress() { rm -f "$PROGRESS_FILE"; }

cfg() {
	local key="$1"
	if [[ ! -f "$CONFIG_FILE" ]]; then
		return 1
	fi
	tomlq -r ".$key" "$CONFIG_FILE" 2>/dev/null
}

cfg_str() {
	local key="$1" default="$2"
	local val
	val=$(cfg "$key" || true)
	[[ -n "$val" && "$val" != "null" ]] && echo "$val" || echo "$default"
}

cfg_arr() {
	local key="$1" default="$2"
	local val
	val=$(cfg "$key | length" || true)
	if [[ -z "$val" || "$val" == "0" || "$val" == "null" ]]; then
		echo "$default"
		return
	fi
	cfg "$key[]"
}

STOW_TARGET="$(cfg_str "stow.target" "$HOME/.config")"
STOW_TARGET="${STOW_TARGET/#\~/$HOME}"

ensure_stow_target() {
	if [[ -e "$STOW_TARGET" && ! -d "$STOW_TARGET" ]]; then
		log_error "stow target exists but is not a directory: $STOW_TARGET"
		exit 1
	fi
	mkdir -p "$STOW_TARGET"
}

prepare_stow() {
	ensure_stow_target
	backup_conflicts
	# Remove real fish dir so stow folds it into a direct symlink instead of descending into it
	if [[ -d "$STOW_TARGET/fish" && ! -L "$STOW_TARGET/fish" ]]; then
		rm -rf "$STOW_TARGET/fish"
	fi
}

cmd_install() {
	local subcmd="${1:-}"

	case "$subcmd" in
	packages) install_packages ;;
	stow) install_stow ;;
	tools) install_tools ;;
	shell) install_shell ;;
	gh) install_gh ;;
	gpg) install_gpg ;;
	sudo) install_sudo ;;
	--reset)
		reset_progress
		info "Install progress reset."
		;;
	"")
		if [[ -f "$PROGRESS_FILE" ]]; then
			warn "Resuming previous install. Run 'dot install --reset' to start over."
		fi
		local steps=(sudo packages stow tools shell gh gpg)
		local step
		for step in "${steps[@]}"; do
			if step_done "$step"; then
				info "Skipping $step (already completed)."
			else
				"install_$step"
				mark_done "$step"
			fi
			echo ""
		done
		reset_progress
		gum style --foreground 212 --bold "Dotfiles installation complete!"
		;;
	*)
		log_error "Unknown install subcommand: $subcmd"
		echo "Usage: dot install [packages|stow|tools|shell|gh|gpg|--reset]"
		exit 1
		;;
	esac
}

install_packages() {
	log_step "Installing essential packages..."
	if [[ ! -f "$CONFIG_FILE" ]]; then
		log_error "dot.toml not found. Run 'dot config' to create it."
		return 1
	fi
	local pkgs
	pkgs=$(cfg_arr "packages.apt" "")
	if [[ -z "$pkgs" ]]; then
		warn "No packages defined in dot.toml under [packages] apt."
		return 0
	fi

	local -a needed=()
	local pkg
	for pkg in $pkgs; do
		if ! dpkg -s "$pkg" &>/dev/null 2>&1; then
			needed+=("$pkg")
		fi
	done

	if [[ ${#needed[@]} -eq 0 ]]; then
		info "All essential packages already installed."
		return 0
	fi

	spin "Installing ${#needed[@]} packages..." bash -c "
        export DEBIAN_FRONTEND=noninteractive
        sudo apt update && sudo apt install -y ${needed[*]}
    "
	info "Essential packages installed."
}

backup_conflicts() {
	local conflicts
	conflicts=$(stow --simulate --dir="$DOTFILES_DIR" --target="$STOW_TARGET" .config 2>&1 |
		awk -v target="$STOW_TARGET" '
			/existing target is neither a link nor a directory:/ {
				sub(/^.*existing target is neither a link nor a directory: /, "")
				print
				next
			}
			/cannot stow .* over existing target .* since neither a link nor a directory/ {
				if (match($0, /over existing target ([^ ]+) since neither/, m)) {
					if (m[1] ~ /^\//) print m[1]
					else print target "/" m[1]
				}
			}
		' |
		sort -u || true)

	if [[ -z "$conflicts" ]]; then
		return 0
	fi

	warn "Backing up conflicting files..."
	while IFS= read -r file; do
		if [[ -n "$file" ]]; then
			if [[ ! -e "$file" ]]; then
				continue
			fi
			local backup
			backup="${file}.bak.$(date +%Y%m%d%H%M%S)"
			info "  $file -> $(basename "$backup")"
			mv "$file" "$backup"
		fi
	done <<<"$conflicts"
}

install_stow() {
	log_step "Stowing dotfiles..."

	if ! command -v stow &>/dev/null; then
		log_error "stow is not installed. Run 'dot install packages' first."
		exit 1
	fi

	prepare_stow

	stow_log --verbose=1 --dir="$DOTFILES_DIR" --target="$STOW_TARGET" .config

	git config --global include.path "$DOTFILES_DIR/.gitconfig"
	info "Git config include.path set."
}

install_tools() {
	log_step "Optional tools..."

	local tool_names=()
	local tool_labels=()
	local tool_checks=()
	local tool_installs=()

	if [[ -f "$CONFIG_FILE" ]]; then
		local tool_data=()
		mapfile -t tool_data < <(tomlq -r '.tools[]? | .name, .description, .check, .install' "$CONFIG_FILE" 2>/dev/null)
		local i
		for ((i = 0; i < ${#tool_data[@]}; i += 4)); do
			local name="${tool_data[$i]}" desc="${tool_data[$((i + 1))]}"
			local check="${tool_data[$((i + 2))]}" install="${tool_data[$((i + 3))]}"
			tool_names+=("$name")
			tool_labels+=("$name ($desc)")
			tool_checks+=("$check")
			tool_installs+=("$install")
		done
	fi

	if [[ ${#tool_names[@]} -eq 0 ]]; then
		warn "No tools defined in dot.toml under [[tools]]."
		return 0
	fi

	local choices
	choices=$(gum choose --no-limit "${tool_labels[@]}" || true)

	if [[ -z "$choices" ]]; then
		info "No optional tools selected."
		return 0
	fi

	for i in "${!tool_labels[@]}"; do
		if echo "$choices" | grep -qF "${tool_labels[$i]}"; then
			install_tool "${tool_names[$i]}" "${tool_checks[$i]}" "${tool_installs[$i]}"
		fi
	done
}

install_shell() {
	local current_shell
	current_shell=$(basename "$SHELL")
	if [[ "$current_shell" == "fish" ]]; then
		info "Fish is already your default shell."
		return 0
	fi

	if ! confirm "Change default shell to fish?"; then
		return 0
	fi

	chsh -s "$(command -v fish)"
	info "Default shell changed to fish. Log out and back in to apply."
}

install_gh() {
	if gh auth status &>/dev/null 2>&1; then
		info "GitHub CLI already authenticated."
		return 0
	fi

	if ! confirm "Login to GitHub CLI?"; then
		return 0
	fi

	gh auth login -s write:gpg_key
	info "GitHub CLI authenticated."
}

install_sudo() {
	local user
	user=$(whoami)

	if sudo -n true 2>/dev/null; then
		info "Passwordless sudo already configured for $user."
		return 0
	fi

	if ! confirm "Enable passwordless sudo for $user?"; then
		return 0
	fi

	local sudoers_file="/etc/sudoers.d/$user"
	echo "$user ALL=(ALL) NOPASSWD:ALL" | sudo tee "$sudoers_file" >/dev/null
	if ! sudo visudo -c -f "$sudoers_file" &>/dev/null; then
		log_error "sudoers validation failed — removing $sudoers_file to avoid lockout."
		sudo rm -f "$sudoers_file"
		return 1
	fi
	sudo chmod 440 "$sudoers_file"
	info "Passwordless sudo configured for $user."
}

gpg_create_key() {
	local name="$1" email="$2" expire="$3" comment="$4" hostname_str="$5" env_tag="$6"
	spin "Creating Ed25519 GPG key..." bash -c "
        gpg --batch --full-generate-key <<GPGEOF
Key-Type: eddsa
Key-Curve: ed25519
Subkey-Type: eddsa
Subkey-Curve: ed25519
Name-Real: ${name}
Name-Comment: ${comment} - ${hostname_str} - ${env_tag}
Name-Email: ${email}
Expire-Date: ${expire}
%no-protection
%commit
GPGEOF
    "
}

gpg_upload_to_github() {
	local key_id="$1" hostname_str="$2" env_tag="$3"
	spin "Adding GPG key to GitHub..." bash -c "
        gpg --armor --export '$key_id' | gh gpg-key add - --title 'GPG Key - ${hostname_str} - ${env_tag} - $(date +%Y-%m-%d)'
    "
}

gpg_configure_git() {
	local name="$1" email="$2" key_id="$3"
	git config --global user.name "$name"
	git config --global user.email "$email"
	git config --global user.signingkey "$key_id"
	git config --global commit.gpgsign true
	git config --global gpg.program gpg
	git config --global include.path "$DOTFILES_DIR/.gitconfig"
}

install_gpg() {
	if ! command -v gpg &>/dev/null; then
		log_error "gpg is not installed. Run 'dot install packages' first."
		return 1
	fi
	if ! command -v gh &>/dev/null; then
		log_error "gh is not installed. Run 'dot install packages' first."
		return 1
	fi
	if ! gh auth status &>/dev/null 2>&1; then
		log_error "GitHub CLI is not authenticated. Run 'dot install gh' first."
		return 1
	fi

	local name email expire
	name="$(cfg_str "gpg.name" "Keksi")"
	email="$(cfg_str "gpg.email" "git@keksi.dev")"
	expire="$(cfg_str "gpg.expire" "3y")"

	local existing_key
	existing_key=$(gpg --list-secret-keys --with-colons "$email" 2>/dev/null | awk -F: '/^sec/ {print $5; exit}' || true)
	if [[ -n "$existing_key" ]]; then
		warn "GPG key already exists for $email (ID: $existing_key). Skipping."
		return 0
	fi

	if ! confirm "Create a GPG signing key for $name <$email>?"; then
		return 0
	fi

	local hostname_str env_tag="Linux"
	hostname_str=$(hostname)
	grep -qi microsoft /proc/version 2>/dev/null && env_tag="WSL"

	gpg_create_key "$name" "$email" "$expire" "GitHub Signing Key" "$hostname_str" "$env_tag"

	local key_id
	key_id=$(gpg --list-secret-keys --with-colons "$email" | awk -F: '/^sec/ {print $5; exit}')
	if [[ -z "$key_id" ]]; then
		log_error "Could not find generated GPG key."
		return 1
	fi

	gpg_upload_to_github "$key_id" "$hostname_str" "$env_tag"
	gpg_configure_git "$name" "$email" "$key_id"
	info "GPG key created and added to GitHub (ID: $key_id)."
}

cmd_config() {
	"${EDITOR:-vim}" "$CONFIG_FILE"
}

cmd_update() {
	local dry_run=false
	[[ "${1:-}" == "--dry-run" ]] && dry_run=true

	log_step "Updating dotfiles..."
	spin "Pulling latest changes..." git -C "$DOTFILES_DIR" pull

	if $dry_run; then
		info "Dry run — showing what would change:"
		stow --simulate --verbose=1 --dir="$DOTFILES_DIR" --target="$STOW_TARGET" --restow .config 2>&1 |
			while IFS= read -r line; do info "$line"; done
		return 0
	fi

	prepare_stow
	stow_log --verbose=1 --dir="$DOTFILES_DIR" --target="$STOW_TARGET" --restow .config
	info "Dotfiles updated."
}

cmd_remove() {
	log_step "Removing dotfile symlinks..."
	if ! confirm "This will remove all dotfile symlinks. Continue?"; then
		return 0
	fi
	stow_log --verbose=1 --dir="$DOTFILES_DIR" --target="$STOW_TARGET" -D .config
	info "Dotfile symlinks removed."
}

show_menu() {
	show_header

	local choice
	choice=$(
		gum choose \
			"Install (full setup)" \
			"Update" \
			"Remove" \
			"Configure passwordless sudo" \
			"Install packages only" \
			"Stow only" \
			"Install optional tools" \
			"Change shell to fish" \
			"Login to GitHub CLI" \
			"Setup GPG signing" \
			"Edit configuration" \
			"Exit"
	)

	case "$choice" in
	"Install (full setup)") cmd_install ;;
	"Update") cmd_update ;;
	"Remove") cmd_remove ;;
	"Configure passwordless sudo") cmd_install sudo ;;
	"Install packages only") cmd_install packages ;;
	"Stow only") cmd_install stow ;;
	"Install optional tools") cmd_install tools ;;
	"Change shell to fish") cmd_install shell ;;
	"Login to GitHub CLI") cmd_install gh ;;
	"Setup GPG signing") cmd_install gpg ;;
	"Edit configuration") cmd_config ;;
	"Exit") exit 0 ;;
	esac
}

usage() {
	echo -e "${BOLD}dot${NC} - dotfiles manager"
	echo ""
	echo -e "${BOLD}Usage:${NC}"
	echo "  dot                    Interactive menu"
	echo "  dot <command>          Run a command directly"
	echo ""
	echo -e "${BOLD}Commands:${NC}"
	echo "  install                Full setup (sudo, packages, stow, tools, shell, gh, gpg)"
	echo "  install <step>         Run a single install step:"
	echo "                           sudo, packages, stow, tools, shell, gh, gpg"
	echo "  install --reset        Clear saved install progress"
	echo "  update                 Pull latest changes and re-stow"
	echo "  update --dry-run       Show what would change without applying"
	echo "  remove                 Remove all dotfile symlinks"
	echo "  config                 Edit dot.toml configuration"
	echo ""
	echo -e "${BOLD}Examples:${NC}"
	echo "  dot install            # full fresh setup (resumes if interrupted)"
	echo "  dot install stow       # just symlink configs"
	echo "  dot update             # pull & re-stow"
	echo "  dot update --dry-run   # preview changes"
	echo "  dot config             # edit configuration"
}

main() {
	local cmd="${1:-}"

	ensure_gum
	ensure_tomlq
	[[ -n "$cmd" ]] && show_header

	if [[ -z "$cmd" ]]; then
		show_menu
		return 0
	fi

	case "$cmd" in
	install)
		shift 2>/dev/null || true
		cmd_install "$@"
		;;
	update)
		shift 2>/dev/null || true
		cmd_update "$@"
		;;
	remove) cmd_remove ;;
	config) cmd_config ;;
	-h | --help | help) usage ;;
	*)
		log_error "Unknown command: $cmd"
		usage
		exit 1
		;;
	esac
}

main "$@"
